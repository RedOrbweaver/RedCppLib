{
    "version": "0.2.0",
    "configurations": 
    [
        {
            "name": "Debug Test Executable",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/tests",  // Path to your compiled executable
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build",
            "miDebuggerPath": "/usr/bin/gdb",  // Path to gdb
            "stopAtConnect": false
        }
    ]
}
